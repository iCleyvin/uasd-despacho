# ── Base de datos ───────────────────────────────────────────────────────────────
POSTGRES_DB=uasd_despacho
POSTGRES_USER=uasd
POSTGRES_PASSWORD=CAMBIA_ESTE_PASSWORD

# ── JWT ─────────────────────────────────────────────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIA_ESTO_POR_128_CARACTERES_HEX_MINIMO
JWT_EXPIRES_IN=8h

# ── CORS ─────────────────────────────────────────────────────────────────────────
# IP o dominio del frontend, sin trailing slash.
# HTTP (sin TLS):  http://10.2.20.3:3001
# HTTPS (con TLS): https://10.2.20.3:3443
CORS_ORIGIN=http://10.2.20.3:3001

# ── Cookies ──────────────────────────────────────────────────────────────────────
# Cambiar a true solo si HTTPS está activo (ssl/cert.pem y ssl/key.pem presentes)
COOKIE_SECURE=false

# ── Admin inicial ─────────────────────────────────────────────────────────────────
# Solo requerido en el PRIMER arranque. Dejar vacío después del primer login.
# Genera con: node -e "console.log(require('crypto').randomBytes(16).toString('base64url'))"
ADMIN_INITIAL_PASSWORD=CAMBIA_ESTO_CONTRASEÑA_SEGURA
