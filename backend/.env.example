# ── Base de datos ──────────────────────────────────────────────────────────────
# Construida automáticamente por docker-compose usando POSTGRES_PASSWORD
DATABASE_URL=postgresql://uasd:CAMBIA_ESTE_PASSWORD@db:5432/uasd_despacho

# Contraseña de la BD — usa una cadena aleatoria larga
# Genera con: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
POSTGRES_PASSWORD=CAMBIA_ESTE_PASSWORD

# ── JWT ────────────────────────────────────────────────────────────────────────
# Mínimo 64 bytes aleatorios en hex
# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIA_ESTO_POR_128_CARACTERES_HEX_MINIMO

# Tiempo de expiración del token (8h recomendado para jornada laboral)
JWT_EXPIRES_IN=8h

# ── Servidor ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Cookies ────────────────────────────────────────────────────────────────────
# true  → solo funciona con HTTPS (recomendado en producción con dominio + certificado)
# false → permite HTTP (necesario si no hay HTTPS, como en despliegue LAN sin TLS)
COOKIE_SECURE=false

# ── CORS ───────────────────────────────────────────────────────────────────────
# IP o dominio del frontend. Múltiples orígenes separados por coma, sin trailing slash.
# Ejemplo producción LAN: http://10.2.20.3:3001
# Ejemplo dominio: https://despacho.uasd.edu.do
CORS_ORIGIN=http://CAMBIA_ESTO:3001

# ── Admin inicial ──────────────────────────────────────────────────────────────
# Solo requerido en el PRIMER arranque cuando la BD está vacía.
# Genera con: node -e "console.log(require('crypto').randomBytes(16).toString('base64url'))"
# Después del primer login, cambia la contraseña y deja esta variable vacía.
ADMIN_INITIAL_PASSWORD=CAMBIA_ESTO_CONTRASEÑA_SEGURA
